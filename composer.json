{
    "name": "extcode/books",
    "type": "typo3-cms-extension",
    "description": "Book Extension",
    "homepage": "https://www.extco.de",
    "license": [
        "GPL-2.0-or-later"
    ],
    "keywords": [
        "TYPO3 CMS",
        "books"
    ],
    "authors": [
        {
            "name": "Daniel Gohlke",
            "email": "ext@extco.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/extcode/books/issues"
    },
    "autoload": {
        "psr-4": {
            "Extcode\\Books\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Extcode\\Books\\Tests\\": "Tests/"
        }
    },
    "config": {
        "bin-dir": ".build/bin",
        "vendor-dir": ".build/vendor",
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true,
            "phpstan/extension-installer": true
        }
    },
    "version": "2.0.0",
    "extra": {
        "typo3/cms": {
            "extension-key": "books",
            "web-dir": ".build/public"
        }
    },
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "ext-json": "*",
        "ext-pdo": "*",
        "typo3/cms-core": "^14.1",
        "typo3/cms-extbase": "^14.1",
        "typo3/cms-fluid": "^14.1"
    },
    "require-dev": {
        "codappix/typo3-php-datasets": "^2.1",
        "codeception/codeception": "^5.0",
        "codeception/module-db": "^3.1",
        "codeception/module-webdriver": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.16",
        "helmich/typo3-typoscript-lint": "^3.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spaze/phpstan-disallowed-calls": "^4.7",
        "staabm/phpstan-todo-by": "^0.3",
        "typo3/cms-fluid-styled-content": "^14.1",
        "typo3/cms-install": "^14.1",
        "typo3/testing-framework": "^9.3",
        "ssch/typo3-rector": "^3.11"
    }
}
